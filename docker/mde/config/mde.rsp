[Siebel_Installation_Details]
INSTALL_TYPE="New Installation"
ORACLE_HOME="/siebel/mde"
SELECTED_LANGUAGES="en"
[Siebel_Installation_Components]
ENTERPRISE_CONTAINER_CONFIGURATION="true"
AI_CONTAINER_CONFIGURATION="true"
SIEBEL_WEB_CLIENT_CONFIGURATION="false"
SIEBEL_WEB_TOOLS_CONFIGURATION="false"
SIEBEL_ENTERPRISE_COMPONENT="TRUE"
SIEBEL_APPLICATION_INTERFACE="TRUE"
DB_REPOSITORY_SUPPORT="FALSE"
ANCESTOR_REPO_SUPPORT="FALSE"
SIEBEL_WEB_CLIENT="FALSE"
SIEBEL_WEB_TOOLS="FALSE"
HTTP_PORT_EC="@@SES_HTTP_PORT@@"
SHUTDOWN_PORT_EC="@@SES_SHUTDOWN_PORT@@"
REDIRECT_PORT_EC="@@SES_REDIRECT_PORT@@"
HTTP_PORT_AI="@@AI_HTTP_PORT@@"
SHUTDOWN_PORT_AI="@@AI_SHUTDOWN_PORT@@"
REDIRECT_PORT_AI="@@AI_REDIRECT_PORT@@"
USERNAME="@@AI_USERNAME@@"
PASSWORD="@@AI_USER_PWD_ENCRYPTED@@"
KEYSTORE_NAME_EC="/config/siebelkeystore.jks"
KEYSTORE_PASSWORD_EC="@@PKI_PWD_ENCRYPTED@@"
KEYSTORE_TYPE_EC="JKS"
TRUSTSTORE_NAME_EC="/config/siebelkeystore.jks"
TRUSTSTORE_PASSWORD_EC="@@PKI_PWD_ENCRYPTED@@"
TRUSTSTORE_TYPE_EC="JKS"
KEYSTORE_NAME_AI="/config/siebelkeystore.jks"
KEYSTORE_PASSWORD_AI="@@PKI_PWD_ENCRYPTED@@"
KEYSTORE_TYPE_AI="JKS"
TRUSTSTORE_NAME_AI="/config/siebelkeystore.jks"
TRUSTSTORE_PASSWORD_AI="@@PKI_PWD_ENCRYPTED@@"
TRUSTSTORE_TYPE_AI="JKS"
DEPLOYMENT_TYPE="standard"
DEPLOYMENT_LOCATION=""
SERVICE_RESTART="true"
