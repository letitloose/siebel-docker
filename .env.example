# Copy this file to .env and fill in values before running docker compose up.

# -------------------------------------------------------------------
# Oracle DB container
# -------------------------------------------------------------------

# Password for the Oracle SYS and SYSTEM accounts
ORACLE_PWD=changeme

# Root directory for runtime data (dumps and webroot). Defaults to ./data.
# On shared storage set this to the mount point, e.g. /mnt/siebel-data
DATA_DIR=./data

# Directory for Oracle datafiles. Defaults to ./oracle-data (local dev).
# On OCI, point this at a dedicated Higher Performance block volume for better
# import and runtime I/O, e.g. /mnt/oracle-data
ORACLE_DATA_DIR=./oracle-data

# Path to the software directory on shared storage. If set, start.sh creates
# a symlink so Docker can find the installer RPMs and Siebel zip at build time.
# Leave unset to use the local ./software directory.
# SOFTWARE_DIR=/mnt/siebel-software

# Filename of the Data Pump export to import (must be in $DATA_DIR/dumps/)
DUMP_FILE=expdb_dev1_pdb1_2026-02-28.dmp

# Number of parallel workers for the schema import. Default 1 (safe for laptops).
# Set to the number of CPUs available to the container for faster imports on OCI.
IMPORT_PARALLEL=1

# -------------------------------------------------------------------
# Image build args (used by build.sh / docker build)
# -------------------------------------------------------------------

# Oracle Linux version used as base for all images
OL_VERSION=8

# Oracle Instant Client 32-bit version (RPMs must be in docker/instantclient/)
ORACLE_IC_VERSION=19.31

# Siebel version
SIEBEL_VERSION=24.9

# Database connection details (used to generate tnsnames.ora inside images)
DB_HOST=db19sbl249
DB_PORT=1521
DB_SERVICE=ORCLPDB1

# PKI / SSL certificate settings (used when building Siebel component images)
PKI_PWD=changeme
PKI_DOMAIN=company.com

# Siebel Gateway ports
GW_HTTP_PORT=4091
GW_SHUTDOWN_PORT=4092
GW_REDIRECT_PORT=4090

# Siebel Server ports
SES_HTTP_PORT=5090
SES_SHUTDOWN_PORT=5092
SES_REDIRECT_PORT=5091

# Siebel Application Interface ports and credentials
AI_HTTP_PORT=6090
AI_SHUTDOWN_PORT=6092
AI_REDIRECT_PORT=6091
AI_USERNAME=SADMIN
AI_USER_PWD=changeme

# Siebel enterprise and MDE settings
SIEBEL_ENTERPRISE=dev01
MDE_HOSTNAME=dev01mde01
GW_TLS_PORT=2320

# -------------------------------------------------------------------
# Container runtime settings
# -------------------------------------------------------------------

# Container hostnames (CGW, SES, SAI use these; MDE_HOSTNAME is set above)
CGW_HOSTNAME=dev01cgw01
SES_HOSTNAME=dev01ses01
SAI_HOSTNAME=dev01sai01

# oracle user/group — passed as build args (baked into the images) and
# as the runtime user: for all four Siebel containers, so build and
# runtime always agree
SIEBEL_UID=29263
SIEBEL_GID=29263

# -------------------------------------------------------------------
# Enterprise bootstrap (used by scripts/bootstrap-mde.sh)
# -------------------------------------------------------------------

# Primary language code for the enterprise and object managers
SIEBEL_PRIMARY_LANG=enu

# Siebel Gateway registry port (also published from the mde container)
GW_REGISTRY_PORT=2322

# Anonymous/guest login password (username is GUESTCST, fixed in
# scripts/bootstrap-mde.sh and init-scripts/setup/01-setup.sql.template)
SIEBEL_ANON_PWD=changeme
