# Copy this file to .env and fill in values before running docker compose up.

# -------------------------------------------------------------------
# Oracle DB container
# -------------------------------------------------------------------

# Password for the Oracle SYS and SYSTEM accounts
ORACLE_PWD=changeme

# Filename of the Data Pump export to import (must be placed in ./dumps/)
DUMP_FILE=expdb_dev1_pdb1_2026-02-28.dmp

# -------------------------------------------------------------------
# Image build args (used by build.sh / docker build)
# -------------------------------------------------------------------

# Oracle Linux version used as base for all images
OL_VERSION=8

# Oracle Instant Client 32-bit version (RPMs must be in docker/instantclient/)
ORACLE_IC_VERSION=19.31

# Siebel version
SIEBEL_VERSION=24.9

# Database connection details (used to generate tnsnames.ora inside images)
DB_HOST=db19sbl249
DB_PORT=1521
DB_SERVICE=ORCLPDB1
