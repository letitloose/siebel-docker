# Shell scripts run inside Linux containers — must be LF or bash fails with
# "bad interpreter" errors on Windows checkouts.
*.sh        text eol=lf
*.sql       text eol=lf
*.template  text eol=lf
*.rsp       text eol=lf

# PowerShell scripts run natively on Windows — must be CRLF or PS 5.1 fails
# to parse here-string terminators ("@) and throws UnexpectedToken errors.
*.ps1       text eol=crlf
